<?xml version="1.0" encoding="UTF-8"?>
<web-ext
    xmlns="http://websphere.ibm.com/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://websphere.ibm.com/xml/ns/javaee http://websphere.ibm.com/xml/ns/javaee/ibm-web-ext_1_1.xsd"
    version="1.1">

    <!-- Context root for the application.
         The app URL on WebSphere is: http://<host>:9080/mprdemo/  -->
    <context-root uri="/mprdemo"/>

    <!-- Serve servlets by class name - needed for annotation-based servlets
         (MPR's @WebServlet in com.vaadin.mpr package) -->
    <enable-serving-servlets-by-class-name value="true"/>

    <!-- Enable JSP/Servlet annotation processing — required for
         Spring's @WebServlet / @WebFilter / @WebListener discovery -->
    <enable-file-serving value="true"/>

</web-ext>
