<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>MPR Deadlock Reproduction</display-name>

    <session-config>
        <!-- Long session timeout so sessions don't expire during testing -->
        <session-timeout>30</session-timeout>
    </session-config>

    <!--
        Spring Security filter.

        On embedded Tomcat (mvn spring-boot:run) Spring Boot auto-registers
        this filter.  On WebSphere WAR deployment we declare it explicitly
        so the container's web.xml processing wires it up reliably.

        The DelegatingFilterProxy lazily looks up the "springSecurityFilterChain"
        bean from the WebApplicationContext on the first request, so startup
        order does not matter.
    -->
    <filter>
        <filter-name>springSecurityFilterChain</filter-name>
        <filter-class>org.springframework.web.filter.DelegatingFilterProxy</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>springSecurityFilterChain</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
        <dispatcher>INCLUDE</dispatcher>
        <dispatcher>ASYNC</dispatcher>
        <dispatcher>ERROR</dispatcher>
    </filter-mapping>

</web-app>
