<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>MPR Deadlock Reproduction</display-name>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!--
        WebSphere fallback: explicitly bootstrap the Spring ApplicationContext.

        On standard containers the SCI mechanism handles this automatically.
        WebSphere Traditional often fails to discover the SCI from
        spring-web.jar, so this listener calls Application.onStartup()
        directly.  It is a no-op if the SCI already ran.

        MUST be declared BEFORE the DelegatingFilterProxy so the Spring
        context exists when the filter's first doFilter() tries to look
        up the "springSecurityFilterChain" bean.
    -->
    <listener>
        <listener-class>org.vaadin.mprdemo.WebSphereBootstrapListener</listener-class>
    </listener>

    <!--
        Spring Security filter.  Lazily resolves the "springSecurityFilterChain"
        bean from the WebApplicationContext on the first request.
    -->
    <filter>
        <filter-name>springSecurityFilterChain</filter-name>
        <filter-class>org.springframework.web.filter.DelegatingFilterProxy</filter-class>
        <async-supported>true</async-supported>
    </filter>
    <filter-mapping>
        <filter-name>springSecurityFilterChain</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
        <dispatcher>INCLUDE</dispatcher>
        <dispatcher>ASYNC</dispatcher>
        <dispatcher>ERROR</dispatcher>
    </filter-mapping>

</web-app>
